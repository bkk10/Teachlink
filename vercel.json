{
  "version": 2,
  "buildCommand": "python -m pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "env": {
    "DJANGO_SETTINGS_MODULE": "teachly.settings.production"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
